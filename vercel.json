{
  "version": 2,
  "name": "novacloud-edge",
  "functions": {
    "api/index.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/realmoney", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "trailingSlash": false
}
